# Python 4 .gitignore - regras comuns para projetos Python

# Byte-compiled / optimized files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
build/
dist/
eggs/
*.egg-info/
.installed.cfg
parts/
sdist/
develop-eggs/
pip-wheel-metadata/
share/python-wheels/

# Virtual environments
.env
.venv/
venv/
ENV/
env/
env.bak/
venv.bak/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage
htmlcov/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.pytest_cache/
.tox/

# PyBuilder
target/

# IDEs and editors
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Jupyter Notebook checkpoints
.ipynb_checkpoints

# Static analysis / caches
.mypy_cache/
.pyre/
.pytype/
.pyright/
.ruff_cache/

# Profiling
.prof

# Logs and databases
*.log
*.sqlite3
*.db

# Secret / environment files
.env.local
.env.*.local

# OS files
.DS_Store
Thumbs.db

# Misc
coverage/
.claude/
docs/